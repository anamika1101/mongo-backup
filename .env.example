# .env.example
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local (matches docker-compose.yml defaults):
MONGO_URI=mongodb://appuser:apppassword@localhost:27017/appdb

# Remote server:
# MONGO_URI=mongodb://appuser:password@your-server-ip:27017/appdb

# MongoDB Atlas:
# MONGO_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/appdb

# Comma-separated databases, or "all"
DATABASES=all

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_BUCKET=mongo-backups
R2_PREFIX=backups

# ── Encryption ────────────────────────────────────────────────────────────────
# Leave blank to disable. Set to a strong passphrase to enable AES-256 GPG.
BACKUP_ENCRYPTION_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
# Slack: Your App → Incoming Webhooks → Webhook URL
SLACK_WEBHOOK=

# Discord: Channel Settings → Integrations → Webhooks → Copy URL
DISCORD_WEBHOOK=

# ── Email Reports (SendGrid) ──────────────────────────────────────────────────
SENDGRID_API_KEY=
REPORT_EMAIL_TO=you@yourdomain.com
REPORT_EMAIL_FROM=backup-bot@yourdomain.com

# ── Retention ─────────────────────────────────────────────────────────────────
KEEP_LAST=14       # 14 = 7 days at 2 backups/day

# ── Retry ─────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY=15     # seconds between retries

# ── Local paths ───────────────────────────────────────────────────────────────
BACKUP_DIR=/tmp/mongo-backup
RESTORE_DIR=/tmp/mongo-restore
